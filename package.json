{
  "name": "referent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "node scripts/free-port.mjs 3010 && next dev -p 3010",
    "dev:clean": "node scripts/free-port.mjs 3010 && node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3010",
    "build": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next build",
    "start": "next start -p 3010"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.21",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.8.3"
  }
}
